{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.9.0"
        },
        {
            "src": "/public/**",
            "use": "@vercel/static"
        },
        {
            "src": "/storage/app/public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/storage/(.*\\.(?:css|js|svg|png|jpg|jpeg|gif|ico|mp4|srt|webmanifest|txt|html))$",
            "dest": "/storage/app/public/$1",
            "headers": {
                "cache-control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/(.*\\.(?:css|js|svg|png|jpg|jpeg|gif|ico|mp4|srt|webmanifest|txt|html))$",
            "dest": "/public/$1",
            "headers": {
                "cache-control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:4VkhnyQh6q4/Ka7L1tKDNs4ecg3hwu5ia0lDJiIHsEQ=",
        "DB_CONNECTION": "mysql",
        "DB_HOST": "gateway01.ap-southeast-1.prod.alicloud.tidbcloud.com",
        "DB_PORT": "4000",
        "DB_DATABASE": "test",
        "DB_USERNAME": "MtcbV88ZauAGQQE.root",
        "DB_PASSWORD": "ouex0ELR0iQJJoIH",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "QUEUE_CONNECTION": "sync",
        "VIEW_COMPILED_PATH": "/tmp",
        "OCR_SPACE_API_KEY": "K83094079088957",
        "CRON_SECRET": "VercelCronSecret123"
    },
    "crons": [
        {
            "path": "/api/cron/trigger",
            "schedule": "0 8 * * *"
        }
    ]
}
